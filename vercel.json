{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "assets/**",
        "css/**",
        "data/**",
        "js/**",
        "card-shell.html",
        "index.html"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
